        {
            anyOf: [{ required: ["text"] }, { required: ["text_blocks"] }]
        }
    ]
};

/** DashScope / OpenAI-compatible wrapper for chat completions body.response_format */
export function combatQuestionJsonSchemaResponseFormat() {
