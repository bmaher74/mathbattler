        visual_spec: {
            anyOf: [
                { type: "null" },
                {
                    type: "object",
                    additionalProperties: false,
                    properties: {
                        viewBox: { type: "string" },
                        elements: { type: "array", minItems: 1, items: GOM_ELEMENT }
                    },
                    required: ["viewBox", "elements"]
                }
            ]
        },
        plotly_spec: { type: "string" },
        type: { type: "string", enum: ["input"] }
    },
    required: [
        "_thought_process",
