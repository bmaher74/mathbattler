        localStorage.setItem(
            BOSS_CACHE_LS_KEY,
            JSON.stringify({
                v: BOSS_CACHE_SCHEMA_VERSION,
                levels: {
                    "5": { name: "x", blurb: "x", hue: "#fff", topic: "A", battleSvg: svg, mapSvg: svg }
                }
            })
