    lsStore = {};
    globalThis.localStorage = {
        getItem: (k) => (Object.prototype.hasOwnProperty.call(lsStore, k) ? lsStore[k] : null),
        setItem: (k, v) => {
            lsStore[k] = String(v);
        },
        removeItem: (k) => {
            delete lsStore[k];
        },
        clear: () => {
