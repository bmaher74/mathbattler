<file path="style.css">
@keyframes shake { 0%, 100% { transform: translateX(0); } 20%, 60% { transform: translateX(-10px); } 40%, 80% { transform: translateX(10px); } }
.animate-shake { animation: shake 0.4s ease-in-out; }
@keyframes attack-p { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-40px); } }
.animate-attack-p { animation: attack-p 0.3s ease-in-out; }
@keyframes attack-e { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(40px); } }
.animate-attack-e { animation: attack-e 0.3s ease-in-out; }

/* Pokémon-style combat: lunges + impact flash (classes toggled from main.js) */
#player-sprite,
#enemy-sprite {
    transition: filter 0.15s ease-out;
    will-change: transform;
}
#player-sprite.combat-player-lunge {
    animation: combat-player-lunge 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}
@keyframes combat-player-lunge {
    0% { transform: translateY(0) scale(1); filter: brightness(1); }
    35% { transform: translateY(-42px) scale(1.06); filter: brightness(1.2) drop-shadow(0 0 12px rgba(96, 165, 250, 0.7)); }
    100% { transform: translateY(-6px) scale(1); filter: brightness(1); }
}
#enemy-sprite.combat-enemy-hit {
    animation: combat-enemy-flinch 0.5s ease-out forwards;
}
@keyframes combat-enemy-flinch {
    0% { transform: translateY(0); filter: brightness(1); }
    25% { transform: translateY(8px) scale(0.94); filter: brightness(1.4) saturate(1.3); }
    100% { transform: translateY(0) scale(1); filter: brightness(1); }
}
#enemy-sprite.combat-enemy-lunge {
    animation: combat-enemy-lunge 0.45s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}
@keyframes combat-enemy-lunge {
    0% { transform: translateY(0) scale(1); }
    40% { transform: translateY(36px) scale(1.08); filter: brightness(1.15) drop-shadow(0 0 14px rgba(248, 113, 113, 0.55)); }
    100% { transform: translateY(0) scale(1); }
}
#player-sprite.combat-player-hit {
    animation: combat-player-hit 0.55s ease-out forwards;
}
@keyframes combat-player-hit {
    0% { transform: translateY(0); }
    30% { transform: translateY(14px) scale(0.92); filter: brightness(0.85); }
    100% { transform: translateY(0) scale(1); filter: brightness(1); }
}
.battle-impact-flash-base {
    background: radial-gradient(ellipse 85% 55% at 50% 38%, rgba(255, 255, 255, 0) 0%, rgba(255, 255, 255, 0) 100%);
    transition: opacity 0.06s linear;
}
#battle-impact-flash.battle-flash-on {
    opacity: 1 !important;
    background: radial-gradient(ellipse 90% 60% at 50% 36%, rgba(255, 251, 235, 0.72) 0%, rgba(251, 191, 36, 0.15) 35%, transparent 62%);
}

@keyframes damage-pop {
    0% { opacity: 0; transform: translateY(10px) scale(0.65); }
    12% { opacity: 1; transform: translateY(0) scale(1.12); }
    100% { opacity: 0; transform: translateY(-36px) scale(1); }
}
.damage-text {
    position: absolute;
    font-weight: 900;
    font-size: clamp(1.4rem, 4.5vw, 2.35rem);
    pointer-events: none;
    z-index: 35;
    line-height: 1;
    text-shadow:
        0 0 12px rgba(0, 0, 0, 0.95),
        0 2px 4px rgba(0, 0, 0, 0.85);
}
#enemy-damage.damage-text {
    color: #fde047;
}
#player-damage.damage-text {
    color: #fca5a5;
}
.animate-damage {
    animation: damage-pop 1s ease-out forwards;
}

/* Shop: upgrade celebration burst + card (Pokémon TCG–style reveal) */
.upgrade-celebration-root {
    transition: opacity 0.35s ease-out;
}
.upgrade-celebration-root.upgrade-celebration-visible {
    opacity: 1;
    pointer-events: auto;
}
.upgrade-celebration-burst {
    position: absolute;
    inset: -20%;
    background: conic-gradient(from 0deg, rgba(251, 191, 36, 0.4), transparent 40%, rgba(168, 85, 247, 0.35), transparent 70%, rgba(251, 191, 36, 0.45));
    animation: upgrade-burst-spin 2.4s linear infinite;
    opacity: 0.65;
}
@keyframes upgrade-burst-spin {
    to { transform: rotate(360deg); }
}
.upgrade-celebration-card {
    animation: upgrade-card-enter 0.55s cubic-bezier(0.34, 1.56, 0.64, 1) forwards;
}
@keyframes upgrade-card-enter {
    0% { opacity: 0; transform: scale(0.4) translateY(24px); }
    100% { opacity: 1; transform: scale(1) translateY(0); }
}
.upgrade-card-shine {
    position: relative;
    overflow: hidden;
}
.upgrade-card-shine::after {
    content: "";
    position: absolute;
    inset: -50%;
    background: linear-gradient(125deg, transparent 40%, rgba(255, 255, 255, 0.12) 48%, rgba(255, 255, 255, 0.22) 50%, rgba(255, 255, 255, 0.12) 52%, transparent 60%);
    animation: upgrade-shine 2.5s ease-in-out infinite;
}
@keyframes upgrade-shine {
    0% { transform: translateX(-30%) translateY(-30%) rotate(0deg); }
    100% { transform: translateX(30%) translateY(30%) rotate(0deg); }
}
@keyframes breathe { 0%, 100% { transform: scaleY(1); } 50% { transform: scaleY(0.965); } }
.enemy-breathe { animation: breathe 2.4s ease-in-out infinite; transform-origin: 50% 80%; }
@keyframes lowhp { 0%, 100% { filter: saturate(1) drop-shadow(0 0 12px rgba(239,68,68,0.25)); } 50% { filter: saturate(1.4) drop-shadow(0 0 18px rgba(239,68,68,0.65)); } }
.enemy-lowhp { animation: breathe 1.4s ease-in-out infinite, lowhp 0.8s ease-in-out infinite; }
.health-fill { transition: width 0.4s cubic-bezier(0.4, 0, 0.2, 1); }
.custom-scrollbar::-webkit-scrollbar { width: 6px; }
.custom-scrollbar::-webkit-scrollbar-thumb { background: #4b5563; border-radius: 4px; }
.h-dvh { height: 100dvh; }
/* Plotly fills this box; keeps charts inside the solution modal */
#plot-container:not(.hidden) {
    width: 100%;
    max-width: 100%;
    height: min(38vh, 280px);
    max-height: min(38vh, 280px);
    min-height: 0;
    overflow: hidden;
}
/* Combat stem: LLM SVG (viewBox 0 0 100 100) scales to readable size */
#question-visual-container:not(.hidden) {
    width: 100%;
    max-width: min(100%, 20rem);
    margin-left: auto;
    margin-right: auto;
}
#question-visual-container:not(.hidden) svg {
    display: block;
    width: 100%;
    height: auto;
    max-height: min(32vh, 220px);
}
@keyframes quest-glow { 0%, 100% { filter: drop-shadow(0 0 6px rgba(250, 204, 21, 0.9)); } 50% { filter: drop-shadow(0 0 14px rgba(250, 204, 21, 1)); } }
.quest-node-current { animation: quest-glow 2.2s ease-in-out infinite; }
.quest-map-wrap { min-height: 0; }
#cloud-sync-badge:not(.hidden) { pointer-events: auto; }
#ai-questions-status { pointer-events: none; }

/* Map HUD modals: must sit above #level-screen (z-50). Tailwind z-[250]/z-[260] only exist after `npm run build:css`; this keeps modals usable if CSS is stale. */
#bestiary-overlay,
#upgrades-overlay,
#practice-overlay {
    z-index: 280;
}

/* Legacy: LLM pipe tables are now flattened to plain lines; class kept for any cached HTML */
#question-text .mb-qtable,
#practice-question-text .mb-qtable,
#personalized-feedback .mb-qtable,
#ideal-explanation .mb-qtable {
    width: 100%;
    border-collapse: collapse;
    margin: 0.5rem 0;
    font-size: 0.875rem;
}
.mb-qtable th,
.mb-qtable td {
    border: 1px solid #64748b;
    padding: 0.35rem 0.5rem;
    text-align: center;
}
.mb-qtable th {
    background: rgba(30, 41, 59, 0.85);
    font-weight: 800;
}

/* Map shard total: spacing between label and number even if Tailwind gap is missing from build */
.map-shards-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
}
.map-shards-pill #shards-count {
    font-variant-numeric: tabular-nums;
    min-width: 1.25em;
}

/* Earned title badges (map HUD): real spacing + icon + pill — not dependent on Tailwind purge */
.player-flair-badges {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    max-width: min(100%, 36rem);
}
.flair-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.2rem 0.55rem 0.2rem 0.4rem;
    border-radius: 9999px;
    border: 1px solid rgba(251, 191, 36, 0.5);
    background: linear-gradient(155deg, rgba(35, 28, 8, 0.98), rgba(67, 48, 6, 0.92));
    box-shadow:
        0 0 0 1px rgba(0, 0, 0, 0.45),
        0 2px 10px rgba(0, 0, 0, 0.4),
        inset 0 1px 0 rgba(255, 255, 255, 0.07);
    font-size: 0.5625rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #fff7ed;
    line-height: 1.25;
    vertical-align: middle;
}
.flair-badge-icon {
    flex-shrink: 0;
    display: block;
    filter: drop-shadow(0 0 5px rgba(251, 191, 36, 0.35));
}
.flair-badge-label {
    white-space: nowrap;
    max-width: 10.5rem;
    overflow: hidden;
    text-overflow: ellipsis;
}
.flair-badge--gold {
    border-color: rgba(251, 191, 36, 0.55);
    color: #fffbeb;
}
.flair-badge--steel {
    border-color: rgba(148, 163, 184, 0.55);
    background: linear-gradient(155deg, rgba(15, 23, 42, 0.98), rgba(30, 41, 59, 0.92));
    color: #e2e8f0;
}
.flair-badge--steel .flair-badge-icon {
    filter: drop-shadow(0 0 4px rgba(148, 163, 184, 0.45));
}
.flair-badge--forest {
    border-color: rgba(52, 211, 153, 0.45);
    background: linear-gradient(155deg, rgba(6, 40, 27, 0.96), rgba(15, 60, 42, 0.92));
    color: #d1fae5;
}
.flair-badge--forest .flair-badge-icon {
    filter: drop-shadow(0 0 4px rgba(52, 211, 153, 0.35));
}
.flair-badge--ember {
    border-color: rgba(251, 146, 60, 0.55);
    background: linear-gradient(155deg, rgba(55, 22, 6, 0.96), rgba(90, 30, 10, 0.92));
    color: #ffedd5;
}
.flair-badge--ember .flair-badge-icon {
    filter: drop-shadow(0 0 5px rgba(251, 146, 60, 0.45));
}
.flair-badge--crystal {
    border-color: rgba(56, 189, 248, 0.5);
    background: linear-gradient(155deg, rgba(8, 30, 50, 0.96), rgba(12, 55, 80, 0.92));
    color: #e0f2fe;
}
.flair-badge--crystal .flair-badge-icon {
    filter: drop-shadow(0 0 5px rgba(56, 189, 248, 0.4));
}
.flair-badge--arcane {
    border-color: rgba(167, 139, 250, 0.5);
    background: linear-gradient(155deg, rgba(35, 20, 60, 0.96), rgba(55, 30, 85, 0.92));
    color: #ede9fe;
}
.flair-badge--arcane .flair-badge-icon {
    filter: drop-shadow(0 0 5px rgba(167, 139, 250, 0.4));
}
.flair-badge--mint {
    border-color: rgba(52, 211, 153, 0.4);
    background: linear-gradient(155deg, rgba(10, 40, 35, 0.96), rgba(15, 55, 48, 0.9));
    color: #ecfdf5;
}
.flair-badge--mint .flair-badge-icon {
    filter: drop-shadow(0 0 4px rgba(45, 212, 191, 0.35));
}

/* Netlify production (runtime-config sets __mathbattler_production_ui__; ?debug=1 restores dev UI) */
.mb-production-ui #test-panel,
.mb-production-ui #cloud-sync-badge,
.mb-production-ui #ai-questions-status,
.mb-production-ui #map-question-buffer-hint,
.mb-production-ui #question-source-badge,
.mb-production-ui #ai-route-notice {
    display: none !important;
}
.mb-production-ui #engagement-toast {
    top: 0.5rem;
}
</file>

