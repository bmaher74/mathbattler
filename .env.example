# Local dev configuration (do not commit .env)

# DashScope (Qwen)
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
DASHSCOPE_MODEL=qwen-flash
# Optional same-origin proxy URL to avoid browser CORS
DASHSCOPE_CHAT_COMPLETIONS_URL=

# Firebase
# Option A (recommended): provide a single JSON string exactly like firebase-config.js expects.
FIREBASE_CONFIG_JSON=

# Option B: provide fields (used only if FIREBASE_CONFIG_JSON is empty)
FIREBASE_API_KEY=
FIREBASE_AUTH_DOMAIN=
FIREBASE_PROJECT_ID=
FIREBASE_STORAGE_BUCKET=
FIREBASE_MESSAGING_SENDER_ID=
FIREBASE_APP_ID=
FIREBASE_MEASUREMENT_ID=

