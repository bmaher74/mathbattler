{
  "name": "mathbattler",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm run build:css && node scripts/generate-runtime-config.mjs",
    "dev:web": "npm run build:css && cd web && npm run dev",
    "build:web": "npm run build:css && node scripts/generate-runtime-config.mjs && cd web && npm run build",
    "preview:web": "cd web && npm run preview",
    "build:css": "tailwindcss -i ./tailwind.input.css -o ./tailwind.css --minify",
    "validate-llm": "node scripts/validate-llm.mjs",
    "test": "node scripts/run-root-tests.mjs",
    "check": "npm test && cd web && npm run typecheck",
    "test:ai": "node --test scripts/test-ai-schemas.mjs",
    "serve": "node scripts/serve-static.mjs"
  },
  "dependencies": {
    "zod": "3.24.1"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "firebase-admin": "^13.0.0",
    "tailwindcss": "^3.4.17"
  }
}
